# =============================================================================
# .env.prod — template para produção
# Copie para .env.prod e preencha todos os valores marcados com <...>
# =============================================================================

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
# Gere com: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=<DJANGO_SECRET_KEY>

# Gere com: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_ENCRYPTION_KEY=<CREDENTIALS_ENCRYPTION_KEY>

DJANGO_SSL_REQUIRE=false
SITE_DOMAIN=<IP_OU_DOMINIO_DO_SERVIDOR>

# -----------------------------------------------------------------------------
# Banco de dados (PostgreSQL)
# Nota: POSTGRES_DB, POSTGRES_USER e POSTGRES_PASSWORD também são usados pelo
# container do postgres para inicializar o banco.
# -----------------------------------------------------------------------------
POSTGRES_DB=attendee_prod
POSTGRES_USER=attendee_user
POSTGRES_PASSWORD=<SENHA_FORTE_POSTGRES>

# DATABASE_URL usa localhost porque todos os serviços rodam em network_mode: host
DATABASE_URL=postgresql://attendee_user:<SENHA_FORTE_POSTGRES>@localhost:5432/attendee_prod
POSTGRES_SSL_REQUIRE=false

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/5

# -----------------------------------------------------------------------------
# Storage — MinIO (S3-compatível)
# AWS_ACCESS_KEY_ID deve ser igual a MINIO_ROOT_USER
# AWS_SECRET_ACCESS_KEY deve ser igual a MINIO_ROOT_PASSWORD
# -----------------------------------------------------------------------------
STORAGE_PROTOCOL=s3

MINIO_ROOT_USER=<MINIO_USER>
MINIO_ROOT_PASSWORD=<MINIO_SENHA_FORTE>

AWS_ACCESS_KEY_ID=<MINIO_USER>
AWS_SECRET_ACCESS_KEY=<MINIO_SENHA_FORTE>
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:9000
AWS_RECORDING_STORAGE_BUCKET_NAME=attendee-recordings
AWS_AUDIO_CHUNK_STORAGE_BUCKET_NAME=attendee-audio-chunks

# -----------------------------------------------------------------------------
# Email (desabilitado por padrão — habilite quando configurar SMTP)
# -----------------------------------------------------------------------------
DISABLE_EMAIL=true
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_HOST_USER=<SMTP_USER>
# EMAIL_HOST_PASSWORD=<SMTP_PASSWORD>
# DEFAULT_FROM_EMAIL=noreply@<SEU_DOMINIO>

# -----------------------------------------------------------------------------
# Segurança / Webhooks
# -----------------------------------------------------------------------------
REQUIRE_HTTPS_WEBHOOKS=false

# -----------------------------------------------------------------------------
# Sentry (opcional — deixe em branco para desabilitar)
# -----------------------------------------------------------------------------
# SENTRY_DSN=

# -----------------------------------------------------------------------------
# Whisper Service
# -----------------------------------------------------------------------------
CUSTOM_ASYNC_TRANSCRIPTION_URL=https://whisper.firstlineai.com.br/transcribe
CUSTOM_ASYNC_TRANSCRIPTION_TIMEOUT=300
